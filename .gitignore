# ─────────────────────────────────────────────────────────────
# WingID — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.eggs/
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── ML Model Weights & Engines ────────────────────────────────
# These are large binary files (50MB–500MB+) — do not commit
*.pt
*.pth
*.ckpt
*.engine
*.onnx
*.trt
*.plan
# HuggingFace model cache
.cache/

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
*.local

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Temporary / Output ────────────────────────────────────────
*.tmp
*.bak
*.orig
output/
exports/
screenshots/
